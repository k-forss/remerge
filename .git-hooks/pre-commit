#!/usr/bin/env bash
# pre-commit hook — runs ci-local.sh before every commit.
#
# Install via:  scripts/install-hooks.sh
# Skip once:    SKIP_CI_HOOK=1 git commit …

set -euo pipefail

if [[ "${SKIP_CI_HOOK:-0}" == "1" ]]; then
  exit 0
fi

REPO_DIR="$(git rev-parse --show-toplevel)"
exec "$REPO_DIR/scripts/ci-local.sh"
